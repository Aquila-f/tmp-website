---
import type { PostEntry } from '../lib/posts';
import { getPostHref } from '../lib/posts';
import { withBase } from '../lib/url';
import ArticleLayout from './ArticleLayout.astro';

const { post, older, newer } = Astro.props as {
  post: PostEntry;
  older?: PostEntry;
  newer?: PostEntry;
};
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description ?? 'An essay by Aquila.'}
  backHref={withBase('/blog/')}
  backLabel="All writing"
  metaLabel="Essay"
  date={post.data.date}
  tags={post.data.tags}
  previous={older && {
    href: getPostHref(older),
    label: 'Older',
    title: older.data.title,
  }}
  next={newer && {
    href: getPostHref(newer),
    label: 'Newer',
    title: newer.data.title,
  }}
>
  <slot />
</ArticleLayout>
