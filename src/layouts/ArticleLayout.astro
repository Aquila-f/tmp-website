---
import { formatBlogDate } from '../lib/blog';
import BaseLayout from './BaseLayout.astro';

type ArticleLink = {
  href: string;
  label: string;
  title: string;
};

const {
  title,
  description,
  backHref,
  backLabel,
  metaLabel,
  date,
  tags = [],
  current = '/blog',
  previous,
  next,
} = Astro.props as {
  title: string;
  description: string;
  backHref: string;
  backLabel: string;
  metaLabel: string;
  date?: Date;
  tags?: string[];
  current?: string;
  previous?: ArticleLink;
  next?: ArticleLink;
};
---

<BaseLayout title={`${title} — Aquila`} {description} {current}>
  <article class="article">
    <header class="article-header">
      <a class="back" href={backHref}>← {backLabel}</a>

      <div class="article-meta">
        <span>{metaLabel}</span>
        <time datetime={date?.toISOString()}>{formatBlogDate(date)}</time>
      </div>

      <h1>{title}</h1>
      {description && <p class="dek">{description}</p>}

      {tags.length > 0 && (
        <ul class="tags" aria-label="Topics">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <nav class="article-nav" aria-label="Article navigation">
      {previous ? (
        <a href={previous.href}>
          <span>{previous.label}</span>
          <strong>{previous.title}</strong>
        </a>
      ) : <span></span>}

      {next && (
        <a class="next" href={next.href}>
          <span>{next.label}</span>
          <strong>{next.title}</strong>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .article {
    margin: 0 auto;
    max-width: 1120px;
  }

  .article-header {
    border-bottom: 1px solid var(--line);
    margin: clamp(3.5rem, 8vw, 6rem) 0 clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .back {
    color: var(--muted);
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    margin-bottom: clamp(3rem, 7vw, 6rem);
    text-decoration: none;
  }

  .back:hover {
    color: var(--ink);
  }

  .article-meta {
    color: var(--accent);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    gap: 1.25rem;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  h1 {
    font-family: var(--font-body);
    font-size: clamp(2.1rem, 4.3vw, 3.6rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.06;
    margin-bottom: 1.5rem;
    max-width: 1050px;
  }

  .dek {
    color: var(--muted);
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    line-height: 1.72;
    max-width: 700px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
  }

  .tags li {
    border: 1px solid var(--line);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 0.45rem 0.6rem;
  }

  .prose {
    font-family: var(--font-display);
    font-size: clamp(1.04rem, calc(0.98rem + 0.25vw), 1.12rem);
    letter-spacing: 0;
    line-height: 1.95;
    margin: 0 auto;
    max-width: 680px;
    overflow-wrap: break-word;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--ink);
    font-family: var(--font-body);
    font-weight: 620;
    letter-spacing: -0.025em;
    line-height: 1.18;
  }

  .prose :global(h2) {
    border-top: 1px solid var(--line);
    font-size: clamp(1.85rem, 3.5vw, 2.45rem);
    margin: 4.75rem 0 1.5rem;
    padding-top: 1.4rem;
  }

  .prose :global(h3) {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    margin: 3.5rem 0 1rem;
  }

  .prose :global(h4) {
    font-size: 1.25rem;
    margin: 2.5rem 0 0.8rem;
  }

  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote),
  .prose :global(pre),
  .prose :global(table) {
    margin-bottom: 1.5rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.55rem 0;
  }

  .prose :global(li::marker) {
    color: var(--accent);
  }

  .prose :global(a) {
    text-decoration-color: color-mix(in srgb, var(--accent) 55%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    color: var(--muted);
    font-size: 1.08em;
    letter-spacing: 0;
    line-height: 1.75;
    margin-left: 0;
    padding-left: 1.25rem;
  }

  .prose :global(code) {
    background: var(--code-inline);
    font-family: var(--font-mono);
    font-size: 0.86em;
    padding: 0.16em 0.35em;
  }

  .prose :global(pre) {
    background: var(--code-block) !important;
    border-radius: 0;
    line-height: 1.65;
    overflow-x: auto;
    padding: clamp(1rem, 3vw, 1.6rem);
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .prose :global(img) {
    background: var(--paper-light);
    height: auto;
    margin: 2.5rem auto;
    max-height: 720px;
    object-fit: contain;
    width: auto;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 3.5rem 0;
  }

  .prose :global(table) {
    border-collapse: collapse;
    display: block;
    font-family: var(--font-body);
    font-size: 0.84rem;
    line-height: 1.55;
    overflow-x: auto;
    width: 100%;
  }

  .prose :global(th),
  .prose :global(td) {
    border-bottom: 1px solid var(--line);
    padding: 0.75rem;
    text-align: left;
  }

  .prose :global(th) {
    font-weight: 650;
  }

  .article-nav {
    border-top: 1px solid var(--ink);
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: clamp(5rem, 10vw, 9rem);
    padding-top: 1rem;
  }

  .article-nav a {
    display: grid;
    gap: 0.5rem;
    text-decoration: none;
  }

  .article-nav .next {
    text-align: right;
  }

  .article-nav span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .article-nav strong {
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 2.4vw, 2rem);
    font-weight: 580;
    line-height: 1.15;
  }

  @media (max-width: 560px) {
    .article-nav {
      grid-template-columns: 1fr;
    }

    .article-nav .next {
      border-top: 1px solid var(--line);
      padding-top: 1rem;
      text-align: left;
    }
  }
</style>
