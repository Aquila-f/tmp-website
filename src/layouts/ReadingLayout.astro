---
import type { ReadingEntry } from '../lib/reading';
import { formatReadingDate, getArticleHref, getSeriesHref } from '../lib/reading';
import BaseLayout from './BaseLayout.astro';

const {
  article,
  seriesTitle,
  previous,
  next,
} = Astro.props as {
  article: ReadingEntry;
  seriesTitle: string;
  previous?: ReadingEntry;
  next?: ReadingEntry;
};
---

<BaseLayout
  title={`${article.data.title} — Aquila`}
  description={article.data.description ?? `Reading notes from ${seriesTitle}.`}
  current="/blog"
>
  <article class="reading-article">
    <header class="article-header">
      <a class="back" href={getSeriesHref(article.data.series)}>← {seriesTitle}</a>

      <div class="article-meta">
        <span>Note {article.data.order}</span>
        <time datetime={article.data.date?.toISOString()}>{formatReadingDate(article.data.date)}</time>
      </div>

      <h1>{article.data.title}</h1>
      {article.data.description && <p class="dek">{article.data.description}</p>}

      {article.data.tags.length > 0 && (
        <ul class="tags" aria-label="Topics">
          {article.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <nav class="article-nav" aria-label="Reading notes">
      {previous ? (
        <a href={getArticleHref(previous)}>
          <span>Previous</span>
          <strong>{previous.data.title}</strong>
        </a>
      ) : <span></span>}

      {next && (
        <a class="next" href={getArticleHref(next)}>
          <span>Next</span>
          <strong>{next.data.title}</strong>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .reading-article {
    margin: 0 auto;
    max-width: 1120px;
  }

  .article-header {
    border-bottom: 1px solid var(--line);
    margin: clamp(4rem, 10vw, 8rem) 0 clamp(3.5rem, 8vw, 6.5rem);
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .back {
    color: var(--muted);
    display: inline-block;
    font-size: 0.68rem;
    margin-bottom: clamp(3rem, 7vw, 6rem);
    text-decoration: none;
  }

  .back:hover {
    color: var(--ink);
  }

  .article-meta {
    color: var(--accent);
    display: flex;
    font-size: 0.66rem;
    gap: 1.25rem;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7.4vw, 7rem);
    font-weight: 400;
    letter-spacing: -0.06em;
    line-height: 0.96;
    margin-bottom: 1.5rem;
    max-width: 1050px;
  }

  .dek {
    color: var(--muted);
    font-size: clamp(0.82rem, 1.2vw, 0.95rem);
    line-height: 1.75;
    max-width: 650px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
  }

  .tags li {
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.6rem;
    padding: 0.45rem 0.6rem;
  }

  .prose {
    font-family: var(--font-mono);
    font-size: clamp(0.82rem, 1.2vw, 0.92rem);
    line-height: 1.9;
    margin: 0 auto;
    max-width: 760px;
    overflow-wrap: anywhere;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 1.18;
  }

  .prose :global(h2) {
    border-top: 1px solid var(--line);
    font-size: clamp(1.9rem, 4vw, 3rem);
    margin: 4.5rem 0 1.4rem;
    padding-top: 1.25rem;
  }

  .prose :global(h3) {
    font-size: clamp(1.45rem, 3vw, 2.1rem);
    margin: 3.25rem 0 1rem;
  }

  .prose :global(h4) {
    font-size: 1.25rem;
    margin: 2.5rem 0 0.8rem;
  }

  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote),
  .prose :global(pre),
  .prose :global(table) {
    margin-bottom: 1.4rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.45rem 0;
  }

  .prose :global(a) {
    text-decoration-color: var(--line);
    text-underline-offset: 0.22em;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    color: var(--muted);
    margin-left: 0;
    padding-left: 1.25rem;
  }

  .prose :global(code) {
    background: rgba(25, 27, 26, 0.06);
    font-size: 0.86em;
    padding: 0.16em 0.35em;
  }

  .prose :global(pre) {
    background: #242725 !important;
    border-radius: 0;
    line-height: 1.65;
    overflow-x: auto;
    padding: clamp(1rem, 3vw, 1.6rem);
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .prose :global(img) {
    background: var(--paper-light);
    height: auto;
    margin: 2.5rem auto;
    max-height: 720px;
    object-fit: contain;
    width: auto;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 3.5rem 0;
  }

  .prose :global(table) {
    border-collapse: collapse;
    display: block;
    font-size: 0.75rem;
    overflow-x: auto;
    width: 100%;
  }

  .prose :global(th),
  .prose :global(td) {
    border-bottom: 1px solid var(--line);
    padding: 0.75rem;
    text-align: left;
  }

  .article-nav {
    border-top: 1px solid var(--ink);
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: clamp(5rem, 10vw, 9rem);
    padding-top: 1rem;
  }

  .article-nav a {
    display: grid;
    gap: 0.5rem;
    text-decoration: none;
  }

  .article-nav .next {
    text-align: right;
  }

  .article-nav span {
    color: var(--muted);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .article-nav strong {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.4vw, 2rem);
    font-weight: 400;
    line-height: 1.15;
  }

  @media (max-width: 560px) {
    .article-nav {
      grid-template-columns: 1fr;
    }

    .article-nav .next {
      border-top: 1px solid var(--line);
      padding-top: 1rem;
      text-align: left;
    }
  }
</style>
