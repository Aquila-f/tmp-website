---
import type { SeriesArticle } from '../lib/reading';
import { getArticleHref, getSeriesHref } from '../lib/reading';
import ArticleLayout from './ArticleLayout.astro';

const {
  article,
  seriesTitle,
  previous,
  next,
} = Astro.props as {
  article: SeriesArticle;
  seriesTitle: string;
  previous?: SeriesArticle;
  next?: SeriesArticle;
};
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description ?? `Reading notes from ${seriesTitle}.`}
  backHref={getSeriesHref(article.data.series)}
  backLabel={seriesTitle}
  metaLabel={`Note ${article.data.order}`}
  date={article.data.date}
  tags={article.data.tags}
  previous={previous && {
    href: getArticleHref(previous),
    label: 'Previous',
    title: previous.data.title,
  }}
  next={next && {
    href: getArticleHref(next),
    label: 'Next',
    title: next.data.title,
  }}
>
  <slot />
</ArticleLayout>
