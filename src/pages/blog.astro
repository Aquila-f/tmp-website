---
import { getCollection } from 'astro:content';
import BlogRow from '../components/blog/BlogRow.astro';
import PageHeader from '../components/PageHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getBookNoteHref,
  getEssayHref,
  getTechnicalSeriesHref,
  isBookNote,
  isEssay,
  isTechnicalNote,
  isTechnicalSeries,
  sortBookNotes,
  sortEssays,
} from '../lib/blog';

const entries = await getCollection('blog');
const essays = sortEssays(entries.filter(isEssay));
const seriesEntries = entries.filter(isTechnicalSeries);
const articles = entries.filter(isTechnicalNote);
const bookNotes = sortBookNotes(entries.filter(isBookNote));

const summaries = seriesEntries
  .map((series) => {
    const seriesArticles = articles.filter((article) => article.data.series === series.data.series);
    const latest = seriesArticles
      .map((article) => article.data.date)
      .filter((date): date is Date => Boolean(date))
      .toSorted((a, b) => b.getTime() - a.getTime())[0];

    return { series, count: seriesArticles.length, latest };
  })
  .toSorted((a, b) => (b.latest?.getTime() ?? 0) - (a.latest?.getTime() ?? 0));
---

<BaseLayout title="Blog — Aquila" current="/blog">
  <PageHeader
    eyebrow="Writing · Notes"
    title="Blog"
    description="Essays, technical study notes, and books that changed how I understand work and life."
  />

  <section class="blog-section" aria-labelledby="essays-title">
    <div class="section-heading">
      <p class="eyebrow">Writing</p>
      <h2 id="essays-title">Essays</h2>
    </div>

    <div class="blog-list">
      {essays.map((essay, index) => (
        <BlogRow
          href={getEssayHref(essay)}
          {index}
          title={essay.data.title}
          description={essay.data.description}
          updated={essay.data.date}
        />
      ))}
    </div>
  </section>

  <section class="blog-section" aria-labelledby="technical-title">
    <div class="section-heading">
      <p class="eyebrow">Engineering</p>
      <h2 id="technical-title">Technical notes</h2>
    </div>

    <div class="blog-list">
      {summaries.map(({ series, count, latest }, index) => (
        <BlogRow
          href={getTechnicalSeriesHref(series.data.series)}
          {index}
          title={series.data.title}
          description={series.data.description}
          updated={latest}
          meta={`${String(count).padStart(2, '0')} notes`}
        />
      ))}
    </div>
  </section>

  <section class="blog-section" aria-labelledby="books-title">
    <div class="section-heading">
      <p class="eyebrow">Reading</p>
      <h2 id="books-title">Book notes</h2>
    </div>

    <div class="blog-list">
      {bookNotes.map((note, index) => (
        <BlogRow
          href={getBookNoteHref(note)}
          {index}
          title={note.data.title}
          description={note.data.description}
          updated={note.data.date}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-section + .blog-section {
    margin-top: clamp(4rem, 8vw, 6.5rem);
  }

  .section-heading {
    display: grid;
    gap: 0.55rem;
    margin-bottom: 1.5rem;
  }

  .section-heading .eyebrow {
    margin: 0 0 0.35rem;
  }

  .section-heading h2 {
    font-family: var(--font-body);
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0;
  }

  .blog-list {
    border-top: 1px solid var(--ink);
  }
</style>
