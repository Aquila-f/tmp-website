---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPostHref, sortPosts } from '../lib/posts';
import { getProjectHref, sortProjects } from '../lib/portfolio';
import { formatReadingDate } from '../lib/reading';
import { withBase } from '../lib/url';

const projects = sortProjects(await getCollection('portfolio')).slice(0, 3);
const posts = sortPosts(await getCollection('posts')).slice(0, 2);

const experience = [
  {
    period: '2026 — Now',
    organization: 'Qualcomm',
    role: 'Senior Engineer',
    detail: 'Computer vision and applied AI',
  },
  {
    period: '2024 — 2026',
    organization: 'Synology',
    role: 'Product Developer',
    detail: 'Generative AI applications and agent systems',
  },
  {
    period: '2023 — 2024',
    organization: 'Academia Sinica',
    role: 'Research Assistant',
    detail: 'Reinforcement learning and CNN–Transformer models',
  },
  {
    period: '2021 — 2023',
    organization: 'NYCU',
    role: 'M.S. in Computer Science and Engineering',
    detail: 'GPA 4.07 / 4.3',
  },
];
---

<BaseLayout
  title="Aquila — Senior Engineer, Computer Vision & AI"
  description="Senior Engineer working on computer vision, applied AI, and production systems."
  current="/"
>
  <header class="home-intro" aria-labelledby="home-title">
    <p class="eyebrow">Aquila Ju</p>
    <div class="intro-copy">
      <h1 id="home-title">Senior engineer working on computer vision and applied AI.</h1>
      <p>
        Currently at Qualcomm in Taipei. Previously building generative AI products at
        Synology and researching reinforcement learning at Academia Sinica.
      </p>
      <nav class="intro-links" aria-label="Homepage links">
        <a href={withBase('/portfolio/')}>Selected work</a>
        <a href={withBase('/blog/')}>Notes</a>
        <a href={withBase('/cv/')}>CV</a>
      </nav>
    </div>
  </header>

  <section class="experience" aria-labelledby="experience-title">
    <header class="section-heading">
      <p class="eyebrow">Background</p>
      <h2 id="experience-title">Experience</h2>
    </header>

    <ol class="timeline">
      {experience.map((item, index) => (
        <li>
          <time>{item.period}</time>
          <span class="track" aria-hidden="true"><span></span></span>
          <div class="entry">
            <div>
              <h3>{item.organization}</h3>
              <p class="role">{item.role}</p>
            </div>
            <p class="detail">{item.detail}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="home-section" aria-labelledby="work-title">
    <header class="section-heading">
      <p class="eyebrow">Work</p>
      <h2 id="work-title">Selected projects</h2>
    </header>

    <div class="work-list">
      {projects.map((project, index) => (
        <a href={getProjectHref(project)}>
          <span class="index">{String(index + 1).padStart(2, '0')}</span>
          <div>
            <h3>{project.data.title}</h3>
            <p>{project.data.category}</p>
          </div>
          <span class="arrow" aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section" aria-labelledby="writing-title">
    <header class="section-heading">
      <p class="eyebrow">Notes</p>
      <h2 id="writing-title">Recent writing</h2>
    </header>

    <div class="post-list">
      {posts.map((post) => (
        <a href={getPostHref(post)}>
          <time datetime={post.data.date.toISOString()}>{formatReadingDate(post.data.date)}</time>
          <h3>{post.data.title}</h3>
          <span aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .home-intro {
    border-top: 1px solid var(--ink);
    display: grid;
    gap: clamp(2rem, 6vw, 6rem);
    grid-template-columns: minmax(8rem, 0.26fr) minmax(0, 1fr);
    margin: clamp(4.5rem, 9vw, 7.5rem) 0 clamp(5rem, 10vw, 8rem);
    padding-top: 1rem;
  }

  .home-intro > .eyebrow { padding-top: 0.4rem; }
  .intro-copy { max-width: 830px; }

  h1 {
    font-size: clamp(2.5rem, 5.2vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.04;
    margin: 0 0 1.5rem;
  }

  .intro-copy > p {
    color: var(--muted);
    font-size: clamp(0.98rem, 1.35vw, 1.12rem);
    line-height: 1.75;
    margin: 0;
    max-width: 680px;
  }

  .intro-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .intro-links a {
    border-bottom: 1px solid var(--line-strong);
    font-size: 0.78rem;
    padding-bottom: 0.25rem;
    text-decoration: none;
  }

  .experience,
  .home-section {
    display: grid;
    gap: clamp(2rem, 6vw, 6rem);
    grid-template-columns: minmax(8rem, 0.26fr) minmax(0, 1fr);
  }

  .home-section { margin-top: clamp(5.5rem, 11vw, 9rem); }

  .section-heading h2 {
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0;
  }

  .section-heading .eyebrow { margin-bottom: 0.65rem; }
  .timeline { list-style: none; margin: 0; padding: 0; }

  .timeline li {
    display: grid;
    grid-template-columns: 7rem 1.25rem minmax(0, 1fr);
    min-height: 6.7rem;
  }

  .timeline time {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    padding-top: 0.25rem;
  }

  .track { position: relative; }

  .track::after {
    background: var(--line);
    bottom: 0;
    content: '';
    left: 4px;
    position: absolute;
    top: 0.65rem;
    width: 1px;
  }

  .timeline li:last-child .track::after { display: none; }

  .track span {
    background: var(--paper);
    border: 1px solid var(--accent);
    border-radius: 50%;
    display: block;
    height: 9px;
    margin-top: 0.35rem;
    position: relative;
    width: 9px;
    z-index: 1;
  }

  .timeline li:first-child .track span { background: var(--accent); }

  .entry {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 1rem 2rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(12rem, 1fr);
    padding: 0 0 1.6rem;
  }

  .timeline li + li .entry { padding-top: 1.55rem; }

  .entry h3 {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin: 0 0 0.25rem;
  }

  .entry p { margin: 0; }
  .role { font-size: 0.78rem; }
  .detail { color: var(--muted); font-size: 0.76rem; line-height: 1.6; }

  .work-list,
  .post-list { border-top: 1px solid var(--ink); }

  .work-list a,
  .post-list a {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: clamp(1rem, 3vw, 3rem);
    padding: 1.35rem 0;
    text-decoration: none;
  }

  .work-list a { grid-template-columns: 2.5rem minmax(0, 1fr) 1rem; }
  .post-list a { grid-template-columns: 7rem minmax(0, 1fr) 1rem; }

  .index,
  .arrow,
  .post-list time,
  .post-list span {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.63rem;
  }

  .work-list h3,
  .post-list h3 {
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 0;
  }

  .work-list p {
    color: var(--muted);
    font-size: 0.65rem;
    margin: 0.25rem 0 0;
  }

  .work-list a:hover h3,
  .post-list a:hover h3 { color: var(--accent); }

  @media (max-width: 700px) {
    .home-intro,
    .experience,
    .home-section { gap: 1.5rem; grid-template-columns: 1fr; }

    .home-intro { margin-top: 3.5rem; }
    .home-intro > .eyebrow { padding-top: 0; }
    .section-heading { border-bottom: 1px solid var(--line); padding-bottom: 1rem; }
    .entry { grid-template-columns: 1fr; }
  }

  @media (max-width: 520px) {
    .timeline li { grid-template-columns: 5.75rem 1.1rem minmax(0, 1fr); }
    .post-list a { grid-template-columns: minmax(0, 1fr) 1rem; }
    .post-list time { grid-column: 1 / -1; }
  }
</style>
