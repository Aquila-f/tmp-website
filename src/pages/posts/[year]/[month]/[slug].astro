---
import { getCollection, render } from 'astro:content';
import EssayLayout from '../../../../layouts/EssayLayout.astro';
import { getEssayRoute, isEssay, sortEssays, type EssayEntry } from '../../../../lib/blog';

export async function getStaticPaths() {
  const essays = sortEssays((await getCollection('blog')).filter(isEssay));

  return essays.map((post, index) => ({
    params: getEssayRoute(post),
    props: {
      post,
      newer: essays[index - 1],
      older: essays[index + 1],
    },
  }));
}

const { post, older, newer } = Astro.props as {
  post: EssayEntry;
  older?: EssayEntry;
  newer?: EssayEntry;
};
const { Content } = await render(post);
---

<EssayLayout {post} {older} {newer}>
  <Content />
</EssayLayout>
