---
import PageHeader from '../components/PageHeader.astro';
import PhotoCard from '../components/photo/PhotoCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPhotos } from '../lib/photos';

const photos = await getPhotos();
---

<BaseLayout title="Photo — Aquila" current="/photo">
  <PageHeader
    eyebrow="Captured moments"
    title="Photo"
    description="Fragments of life, preserved in photographs."
  />

  <section class="gallery" aria-label="Photographs">
    {photos.map((photo) => <PhotoCard photo={photo} />)}
  </section>
</BaseLayout>

<style>
  .gallery {
    display: grid;
    gap: clamp(1.75rem, 3vw, 3rem) clamp(1.25rem, 2.5vw, 2.5rem);
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  @media (max-width: 1000px) {
    .gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
