---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import PageHeader from '../components/PageHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjectHref, sortProjects } from '../lib/portfolio';

const projects = sortProjects(await getCollection('portfolio'));
const tones = ['clay', 'moss', 'ink'];
---

<BaseLayout title="Portfolio — Aquila" current="/portfolio">
  <PageHeader
    eyebrow="Selected work"
    title="Portfolio"
    description="AI products, agent systems, and research shaped by measurable quality, reliable engineering, and thoughtful user experience."
  />

  <section class="projects" aria-label="Selected projects">
    {projects.map((project, index) => (
      <a class="project" href={getProjectHref(project)}>
        <div class:list={['project-image', tones[index % tones.length]]}>
          {project.data.image ? (
            <Image
              src={project.data.image}
              alt={project.data.imageAlt ?? `${project.data.title} project preview`}
              widths={[480, 720, 1024]}
              sizes="(max-width: 650px) 100vw, 50vw"
            />
          ) : (
            <span class="shape" aria-hidden="true"></span>
          )}
          <span class="project-number">{String(index + 1).padStart(2, '0')}</span>
        </div>
        <div class="project-info">
          <div>
            <h2>{project.data.title}</h2>
            {project.data.category && <p class="category">{project.data.category}</p>}
            <p class="excerpt">{project.data.excerpt}</p>
          </div>
          <time datetime={project.data.date.toISOString()}>{project.data.date.getUTCFullYear()}</time>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .projects {
    display: grid;
    gap: clamp(2.5rem, 6vw, 6rem) clamp(1.5rem, 3vw, 3rem);
    grid-template-columns: repeat(2, 1fr);
  }

  .project {
    text-decoration: none;
  }

  .project-image {
    align-items: center;
    aspect-ratio: 16 / 9;
    display: flex;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .project-image :global(img) {
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(.2,.8,.2,1);
    width: 100%;
  }

  .clay { background: #c5a28c; }
  .moss { background: #747a62; }
  .ink { background: #333b3b; }

  .shape {
    border: 1px solid rgba(244, 240, 230, 0.75);
    height: 58%;
    transform: rotate(8deg);
    transition: transform 600ms cubic-bezier(.2,.8,.2,1);
    width: 34%;
  }

  .moss .shape {
    border-radius: 50%;
    height: 52%;
    transform: none;
    width: 52%;
  }

  .ink .shape {
    border-width: 0 0 1px 1px;
    transform: rotate(-45deg);
  }

  .project:hover .shape {
    transform: rotate(0deg) scale(1.06);
  }

  .project:hover .project-image :global(img) {
    transform: scale(1.015);
  }

  .project:hover h2 {
    color: var(--accent);
  }

  .project-number {
    bottom: 1rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    position: absolute;
    right: 1rem;
    text-shadow: 0 1px 4px rgba(25, 27, 26, 0.7);
  }

  .project-info {
    align-items: start;
    display: flex;
    gap: 2rem;
    justify-content: space-between;
    padding-top: 1rem;
  }

  h2 {
    font-family: var(--font-body);
    font-size: clamp(1.35rem, 2.3vw, 2.1rem);
    font-weight: 580;
    letter-spacing: -0.035em;
    line-height: 1.2;
    margin-bottom: 0.45rem;
    transition: color 180ms ease;
  }

  .project-info p,
  .project-info > time {
    color: var(--muted);
    font-size: 0.76rem;
  }

  .project-info .category {
    color: var(--accent);
    letter-spacing: 0.05em;
    margin: 0 0 0.55rem;
    text-transform: uppercase;
  }

  .project-info .excerpt {
    font-size: 0.8rem;
    line-height: 1.65;
    margin: 0;
    max-width: 560px;
  }

  @media (max-width: 650px) {
    .projects {
      grid-template-columns: 1fr;
    }

  }
</style>
