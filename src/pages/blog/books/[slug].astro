---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getArticleSlug, isBookNote, type BookNote } from '../../../lib/reading';
import { withBase } from '../../../lib/url';

export async function getStaticPaths() {
  const notes = (await getCollection('reading')).filter(isBookNote);

  return notes.map((note) => ({
    params: { slug: getArticleSlug(note) },
    props: { note },
  }));
}

const { note } = Astro.props as { note: BookNote };
const { Content } = await render(note);
---

<ArticleLayout
  title={note.data.title}
  description={note.data.description ?? 'Book notes.'}
  backHref={withBase('/blog/')}
  backLabel="All book notes"
  metaLabel="Book note"
  date={note.data.date}
  tags={note.data.tags}
>
  <Content />
</ArticleLayout>
