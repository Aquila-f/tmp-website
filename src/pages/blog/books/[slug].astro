---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getEntrySlug, isBookNote, type BookNoteEntry } from '../../../lib/blog';
import { withBase } from '../../../lib/url';

export async function getStaticPaths() {
  const notes = (await getCollection('blog')).filter(isBookNote);

  return notes.map((note) => ({
    params: { slug: getEntrySlug(note) },
    props: { note },
  }));
}

const { note } = Astro.props as { note: BookNoteEntry };
const { Content } = await render(note);
---

<ArticleLayout
  title={note.data.title}
  description={note.data.description ?? 'Book notes.'}
  backHref={withBase('/blog/')}
  backLabel="All book notes"
  metaLabel="Book note"
  date={note.data.date}
  tags={note.data.tags}
>
  <Content />
</ArticleLayout>
