---
import { getCollection, render } from 'astro:content';
import TechnicalNoteLayout from '../../../layouts/TechnicalNoteLayout.astro';
import {
  getEntrySlug,
  isTechnicalNote,
  isTechnicalSeries,
  sortTechnicalNotes,
  type TechnicalNoteEntry,
} from '../../../lib/blog';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  const seriesEntries = entries.filter(isTechnicalSeries);
  const articles = entries.filter(isTechnicalNote);

  return articles.map((article) => {
    const siblings = sortTechnicalNotes(articles.filter((entry) => entry.data.series === article.data.series));
    const index = siblings.findIndex((entry) => entry.id === article.id);
    const series = seriesEntries.find((entry) => entry.data.series === article.data.series);

    if (!series) throw new Error(`Missing series entry: ${article.data.series}`);

    return {
      params: {
        series: article.data.series,
        slug: getEntrySlug(article),
      },
      props: {
        article,
        seriesTitle: series.data.title,
        previous: siblings[index - 1],
        next: siblings[index + 1],
      },
    };
  });
}

const { article, seriesTitle, previous, next } = Astro.props as {
  article: TechnicalNoteEntry;
  seriesTitle: string;
  previous?: TechnicalNoteEntry;
  next?: TechnicalNoteEntry;
};
const { Content } = await render(article);
---

<TechnicalNoteLayout {article} {seriesTitle} {previous} {next}>
  <Content />
</TechnicalNoteLayout>
