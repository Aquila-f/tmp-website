---
import type { SeriesEntry } from '../../lib/reading';
import { formatReadingDate, getSeriesHref } from '../../lib/reading';

const {
  series,
  count,
  latest,
  index,
} = Astro.props as {
  series: SeriesEntry;
  count: number;
  latest?: Date;
  index: number;
};
---

<a class="series-card" href={getSeriesHref(series.data.series)}>
  <span class="number">{String(index + 1).padStart(2, '0')}</span>

  <div class="copy">
    <p class="kind">Technical series</p>
    <h2>{series.data.title}</h2>
    {series.data.description && <p class="description">{series.data.description}</p>}
  </div>

  <div class="meta">
    <span>{String(count).padStart(2, '0')} notes</span>
    <span>Updated {formatReadingDate(latest)}</span>
  </div>

  <span class="arrow" aria-hidden="true">↗</span>
</a>

<style>
  .series-card {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: clamp(1.25rem, 3vw, 3rem);
    grid-template-columns: 2.5rem minmax(0, 1fr) auto 1rem;
    min-height: 6.75rem;
    padding: 1.35rem 0;
    text-decoration: none;
  }

  .series-card:first-child {
    border-top: 1px solid var(--ink);
  }

  .number,
  .kind,
  .meta,
  .arrow {
    color: var(--muted);
    font-size: 0.66rem;
  }

  .kind {
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  h2 {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 0.4rem;
    transition: color 180ms ease;
  }

  .description {
    color: var(--muted);
    font-size: 0.75rem;
    line-height: 1.7;
    margin: 0;
    max-width: 600px;
  }

  .meta {
    display: grid;
    gap: 0.5rem;
    padding-top: 0;
    white-space: nowrap;
  }

  .arrow {
    color: var(--ink);
    font-size: 0.9rem;
    padding-top: 0;
    transition: transform 180ms ease;
  }

  .series-card:hover h2 {
    color: var(--accent);
  }

  .series-card:hover .arrow {
    transform: translate(3px, -3px);
  }

  @media (max-width: 700px) {
    .series-card {
      grid-template-columns: 2rem minmax(0, 1fr) 1rem;
    }

    .meta {
      display: flex;
      grid-column: 2;
      padding-top: 0;
    }

    .arrow {
      grid-column: 3;
      grid-row: 1;
    }
  }
</style>
