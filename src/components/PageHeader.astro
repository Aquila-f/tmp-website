---
const { eyebrow, title, description } = Astro.props as {
  eyebrow: string;
  title: string;
  description: string;
};
---

<header class="page-header">
  <p class="eyebrow">{eyebrow}</p>
  <div class="copy">
    <h1>{title}</h1>
    <p>{description}</p>
  </div>
</header>

<style>
  .page-header {
    border-top: 1px solid var(--ink);
    display: grid;
    gap: clamp(2rem, 5vw, 5rem);
    grid-template-columns: minmax(7rem, 0.28fr) minmax(0, 1fr);
    margin: clamp(3.5rem, 7vw, 5.5rem) 0 clamp(3rem, 6vw, 4.5rem);
    padding-top: 1rem;
  }

  .eyebrow {
    margin: 0;
    padding-top: 0.45rem;
  }

  .copy {
    max-width: 850px;
  }

  h1 {
    font-family: var(--font-body);
    font-size: clamp(2.15rem, 4.2vw, 3.6rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.04;
    margin: 0 0 1rem;
  }

  .copy p {
    color: var(--muted);
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    line-height: 1.75;
    margin: 0;
    max-width: 680px;
  }

  @media (max-width: 640px) {
    .page-header {
      gap: 1.5rem;
      grid-template-columns: 1fr;
    }

    .eyebrow {
      padding-top: 0;
    }
  }
</style>
